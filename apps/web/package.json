{
  "name": "@jaxego/web",
  "version": "0.1.0",
  "description": "Jaxegô — shell frontend + design system (entregador / loja / admin)",
  "private": true,
  "scripts": {
    "tokens:build": "node scripts/build-tokens.mjs",
    "prebuild": "npm run tokens:build",
    "prestart": "npm run tokens:build",
    "pretest": "npm run tokens:build",
    "start": "ionic serve --proxy-config proxy.conf.json",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false --browsers=ChromeHeadlessCI",
    "lint": "ng lint",
    "verify:visual": "node scripts/visual-baseline.mjs"
  },
  "dependencies": {
    "@angular/common": "19.2.14",
    "@angular/compiler": "19.2.14",
    "@angular/core": "19.2.14",
    "@angular/forms": "19.2.14",
    "@angular/platform-browser": "19.2.14",
    "@angular/platform-browser-dynamic": "19.2.14",
    "@angular/router": "19.2.14",
    "@capacitor/core": "6.2.1",
    "@fontsource/fraunces": "5.2.5",
    "@fontsource/inter-tight": "5.2.5",
    "@fontsource/jetbrains-mono": "5.2.5",
    "@fortawesome/angular-fontawesome": "^1.0.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@ionic/angular": "8.8.9",
    "ionicons": "7.4.0",
    "maplibre-gl": "^5.24.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "19.2.18",
    "@angular-eslint/builder": "19.8.1",
    "@angular-eslint/eslint-plugin": "19.8.1",
    "@angular-eslint/eslint-plugin-template": "19.8.1",
    "@angular-eslint/schematics": "19.8.1",
    "@angular-eslint/template-parser": "19.8.1",
    "@angular/cli": "19.2.18",
    "@angular/compiler-cli": "19.2.14",
    "@capacitor/cli": "6.2.1",
    "@types/jasmine": "5.1.7",
    "eslint": "9.20.0",
    "jasmine-core": "5.5.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.1.0",
    "typescript": "5.7.3",
    "typescript-eslint": "8.24.0"
