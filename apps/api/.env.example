# Jaxego API — environment template.
# Copie para `.env` (ignorado pelo git) e preencha com valores reais.
# NUNCA commite segredos reais — apenas placeholders aqui.

# Ambiente: dev | staging | production | test
ENVIRONMENT=dev
APP_VERSION=0.1.0

# Banco de dados (MySQL 8.0, async via aiomysql, utf8mb4)
# Em Docker Compose o host é o nome do serviço: mysql
DATABASE_URL=mysql+aiomysql://jaxego:jaxego@localhost:3306/jaxego?charset=utf8mb4

# Redis (cache + filas arq)
# Em Docker Compose o host é o nome do serviço: redis
REDIS_URL=redis://localhost:6379/0

# Sentry — opcional. Ausente => Sentry em no-op (não inicializa, não quebra dev).
# Preencha apenas em staging/production com o DSN real (segredo).
SENTRY_DSN=

# Nível de log
LOG_LEVEL=INFO

# --- Auth / JWT (Phase 2) ---
# SEGREDO: gere >=256 bits, ex.: `python -c "import secrets;print(secrets.token_urlsafe(48))"`.
# NUNCA commite o valor real — apenas este placeholder. Obrigatório em staging/production.
JWT_SECRET=changeme-generate-a-256bit-secret-via-secrets-token-urlsafe
# JWT_ALGORITHM=HS256
# JWT_ISSUER=jaxego
# JWT_AUDIENCE=jaxego-api
# ACCESS_TOKEN_MINUTES=15
# REFRESH_TOKEN_DAYS=30

# --- Credenciais do MySQL para o Docker Compose (apenas dev local) ---
MYSQL_ROOT_PASSWORD=changeme-root
MYSQL_DATABASE=jaxego
MYSQL_USER=jaxego
MYSQL_PASSWORD=jaxego

# --- Integrações externas (Phase 4) ---
# Em dev/test a factory retorna adapters Stub (NUNCA rede). Estes valores só são
# lidos pelos adapters httpx reais em staging/production. Allowlists protegem
# contra SSRF (TH-02/TH-03): só hosts listados podem ser alvo de requisição.

# Receita Federal (minhareceita primário + BrasilAPI fallback — DRV-006)
RECEITA_BASE_URL=https://minhareceita.org
RECEITA_BRASILAPI_URL=https://brasilapi.com.br/api/cnpj/v1
RECEITA_ALLOWLIST_HOSTS=minhareceita.org,brasilapi.com.br

# SMS OTP (Zenvia primário + Twilio fallback — DRV-007). SEGREDOS: só via env.
SMS_ZENVIA_URL=https://api.zenvia.com/v2/channels/sms/messages
SMS_ZENVIA_TOKEN=changeme-zenvia-token-secret
SMS_TWILIO_URL=
SMS_TWILIO_TOKEN=changeme-twilio-token-secret
SMS_ALLOWLIST_HOSTS=api.zenvia.com

# E-mail (AWS SES — confirmação por link). SEGREDO: só via env.
SES_SEND_URL=https://email.sa-east-1.amazonaws.com/send
SES_API_TOKEN=changeme-ses-token-secret
SES_ALLOWLIST_HOSTS=email.sa-east-1.amazonaws.com

# --- Backblaze B2 (Phase 5) — documentos KYC, bucket PRIVADO (ADR-004) ---
# B2 é S3-compatible; usamos boto3 (S3v4). B2_KEY_ID/B2_APP_KEY são SEGREDOS:
# só via env, NUNCA commitados (Gate 8 FAIL-BLOCK). Em dev/test a factory usa o
# Stub (filesystem temp, sem rede) — estes valores não são lidos.
# Se um segredo for commitado por engano: ROTACIONE no painel B2 imediatamente.
B2_KEY_ID=changeme-b2-key-id
B2_APP_KEY=changeme-b2-application-key-secret
B2_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com
B2_REGION=us-west-004
B2_KYC_BUCKET=jaxego-kyc-prod
B2_ALLOWLIST_HOSTS=s3.us-west-004.backblazeb2.com

# Geocoding (Nominatim/OSM atrás de adapter — Discretion; self-host recomendado)
GEOCODING_BASE_URL=https://nominatim.openstreetmap.org
GEOCODING_ALLOWLIST_HOSTS=nominatim.openstreetmap.org

# --- OSRM routing (Phase 8) — ETA/distancia para o ranking do despacho ---
# Em dev/test a factory usa o Stub haversine (sem rede). O adapter real degrada a
# haversine x1.4 (eta_degraded) em qualquer falha — NUNCA bloqueia a cascata (TH-8).
# OSRM_ALLOWLIST_HOSTS fecha SSRF (TH-9/A10).
OSRM_BASE_URL=https://router.project-osrm.org
OSRM_PROFILE=driving
OSRM_ALLOWLIST_HOSTS=router.project-osrm.org

# --- Web Push VAPID (Phase 8) — notificacao de oferta/aceite ---
# VAPID_PRIVATE_KEY e SEGREDO: so via env, NUNCA commitado (Gate 8 FAIL-BLOCK; se
# commitado por engano, ROTACIONE). Em dev/test a factory usa o Stub (sem rede).
# Payload de push SEM PII (LOW-5): so delivery_id + deep link + titulo.
VAPID_PRIVATE_KEY=changeme-vapid-private-key-secret
VAPID_PUBLIC_KEY=changeme-vapid-public-key
VAPID_CLAIM_SUB=mailto:ops@jaxego.com.br

# --- Safe2Pay payment core (Phase 10) — DINHEIRO REAL ---
# Em dev/test a factory usa o PaymentStubAdapter (sem rede, sem sandbox). Os valores
# abaixo so sao consultados pelo adapter httpx real em staging/producao.
# TODOS os segredos sao SO via env (Gate 8 FAIL-BLOCK se commitado; se vazar, ROTACIONE
# — nao basta remover do historico). Gerar chaves:
#   SAFE2PAY_TOKEN_ENCRYPT_KEY: openssl rand -hex 32      (64 chars hex = 32 bytes)
#   RSA: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout
SAFE2PAY_API_KEY=changeme-safe2pay-api-key-secret
# true em staging; false em producao (token recorrente so funciona em producao — Pitfall 5)
SAFE2PAY_SANDBOX=true
SAFE2PAY_TOKEN_ENCRYPT_KEY=changeme-64-hex-chars-32-bytes-aes-256-gcm-key-0000000000000000
# Segredo HMAC do webhook ([ASSUMIDO A4] — confirmar no contrato/painel Safe2Pay, T-13)
SAFE2PAY_WEBHOOK_SECRET=changeme-webhook-hmac-secret
# Par RSA-2048 (PEM ou base64(PEM)). Privada SO no backend; publica servida via GET.
RSA_PRIVATE_KEY=changeme-rsa-private-key-pem-or-base64
RSA_PUBLIC_KEY=changeme-rsa-public-key-pem-or-base64
# 3 subdominios Safe2Pay (payment cria / api administra / services consulta) — allowlist SSRF
SAFE2PAY_PAYMENT_URL=https://payment.safe2pay.com.br
SAFE2PAY_API_URL=https://api.safe2pay.com.br
SAFE2PAY_SERVICES_URL=https://services.safe2pay.com.br
SAFE2PAY_ALLOWLIST_HOSTS=payment.safe2pay.com.br,api.safe2pay.com.br,services.safe2pay.com.br
# Subconta/recebedor Jaxego (recebe a taxa). Cadastrar no painel Safe2Pay.
SAFE2PAY_JAXEGO_RECIPIENT=changeme-jaxego-recipient-id
# Revenue share padrao por area (OQ-1 / A7) — parametrizado, nunca hardcoded
REVENUE_SHARE_DEFAULT_PCT=20
