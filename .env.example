# Jaxego API — environment template.
# Copie para `.env` (ignorado pelo git) e preencha com valores reais.
# NUNCA commite segredos reais — apenas placeholders aqui.

# Ambiente: dev | staging | production | test
ENVIRONMENT=dev
APP_VERSION=0.1.0

# Banco de dados (MySQL 8.0, async via aiomysql, utf8mb4)
# Em Docker Compose o host é o nome do serviço: mysql
DATABASE_URL=mysql+aiomysql://jaxego:jaxego@localhost:3306/jaxego?charset=utf8mb4

# Redis (cache + filas arq)
# Em Docker Compose o host é o nome do serviço: redis
REDIS_URL=redis://localhost:6379/0

# Sentry — opcional. Ausente => Sentry em no-op (não inicializa, não quebra dev).
# Preencha apenas em staging/production com o DSN real (segredo).
SENTRY_DSN=

# Nível de log
LOG_LEVEL=INFO

# --- Auth / JWT (Phase 2) ---
# SEGREDO: gere >=256 bits, ex.: `python -c "import secrets;print(secrets.token_urlsafe(48))"`.
# NUNCA commite o valor real — apenas este placeholder. Obrigatório em staging/production.
JWT_SECRET=changeme-generate-a-256bit-secret-via-secrets-token-urlsafe
# JWT_ALGORITHM=HS256
# JWT_ISSUER=jaxego
# JWT_AUDIENCE=jaxego-api
# ACCESS_TOKEN_MINUTES=15
# REFRESH_TOKEN_DAYS=30

# --- Credenciais do MySQL para o Docker Compose (apenas dev local) ---
MYSQL_ROOT_PASSWORD=changeme-root
MYSQL_DATABASE=jaxego
MYSQL_USER=jaxego
MYSQL_PASSWORD=jaxego
