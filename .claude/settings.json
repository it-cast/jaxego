    "_note_for_claude": "Voc\u00ea (Claude) tem permiss\u00f5es completas neste projeto. Nunca pergunte permiss\u00e3o para: criar/mover/deletar arquivos e pastas, instalar packages (npm/pip/cargo/gem/composer), fazer git operations (commit, push, pull, branch, merge, rebase), rodar testes/lint/build, executar Docker/Kubernetes/Terraform, manipular DB (mysql/psql/redis/mongo), invocar APIs (curl/wget/httpie), executar scripts shell em qualquer plataforma (bash/zsh/PowerShell/cmd), abrir arquivos no editor (code, open, start, xdg-open), ou rodar qualquer comando esperado em desenvolvimento, infra, DevOps ou QA. Funciona em Linux, macOS, Windows (PowerShell + cmd + WSL). S\u00f3 pergunte permiss\u00e3o se for fazer algo CLARAMENTE destrutivo fora do escopo do projeto (ex: rm -rf /, sudo apt remove kernel, push --force em main sem confirma\u00e7\u00e3o pr\u00e9via, drop database de produ\u00e7\u00e3o sem backup, formatar disco)."
  },
  "_comment_statusline": "Status line shown na barra inferior do Claude Code.",
  "statusLine": {
    "type": "command",
    "command": "node .claude/hooks/gsd-statusline.js"
  },
  "_comment_hooks": "Hooks do GSD framework. Formato can\u00f4nico {type, command}.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-context-monitor.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-state-guard.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-suggestion-detector.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-skill-application-check.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-metrics-trigger.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-uat-promoter.js"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-prompt-guard.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-workflow-guard.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-skill-loader.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-read-guard.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/gsd-phase-boundary.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/gsd-validate-commit.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/gsd-phase-transition-guard.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/gsd-session-state.sh"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-check-update.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-state-integrity-check.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-projeto-watcher.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/gsd-td-aging.js"
          }
        ]
      }
    ]
  },
  "env": {
    "GSD_CONTEXT_WARNING_THRESHOLD": "35",
    "GSD_CONTEXT_CRITICAL_THRESHOLD": "25",
    "GSD_SKILL_LOADER_ENABLED": "1",
    "GSD_STATE_GUARD_ENABLED": "1",
    "GSD_METRICS_TRIGGER_ENABLED": "1",
    "GSD_UAT_PROMOTER_ENABLED": "1",
    "GSD_SUGGESTION_DETECTOR_ENABLED": "1",
    "GSD_SKILL_APPLY_CHECK_ENABLED": "1",
    "GSD_PARALLEL_AGENTS_ENABLED": "1",
    "GSD_PROJETO_WATCHER_ENABLED": "1",
    "GSD_TD_AGING_ENABLED": "1"
  }
}